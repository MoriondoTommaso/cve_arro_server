# Copy to .env and tailor.
# Comma-separated list. Each entry is `path` or `label=path`.
ARRO_SERVER_DATA_ROOTS=main=./example_data

# Allowed CORS origins (comma-separated).
# WARNING: "*" allows all origins. Restrict this in production.
# Example: ARRO_SERVER_CORS_ORIGINS=https://app.example.com,https://admin.example.com
ARRO_SERVER_CORS_ORIGINS=*

# Default page size for /data requests when limit is omitted.
ARRO_SERVER_DEFAULT_WINDOW=100

# Hard cap on the number of rows (leading-axis elements) per /data or /slice
# response. For N-D arrays total element count = max_window * product(shape[1:]).
ARRO_SERVER_MAX_WINDOW=10000

# Whether to mount the bundled frontend at /ui (true|false).
ARRO_SERVER_SERVE_FRONTEND=true

# Bind host/port for `python -m arro_server`.
ARRO_SERVER_HOST=0.0.0.0
ARRO_SERVER_PORT=8000
ARRO_SERVER_RELOAD=0

# Directory where ArrowSpace graph-Laplacian Zarr arrays are stored.
# Created automatically on first POST /datasets/{id}/index.
ARRO_SERVER_INDEX_STORE=./arrowspace_index

# Maximum number of ArrowSpace indices to keep in memory simultaneously.
# Oldest entry is evicted when the limit is reached.
ARRO_SERVER_INDEX_CACHE_SIZE=8

# Default graph params passed to ArrowSpaceBuilder.build() when the
# POST body omits them.
# ARRO_SERVER_INDEX_GRAPH_PARAMS={"eps": 1.0, "k": 6, "topk": 3, "p": 2.0, "sigma": 1.0}
