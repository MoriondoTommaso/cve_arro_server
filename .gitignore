# ── macOS metadata (NEVER commit these) ─────────────────────────────────────
# To remove already-tracked files run:
#   git rm --cached .DS_Store src/.DS_Store
#   git commit -m "chore: stop tracking .DS_Store files"
**/.DS_Store
.DS_Store
.AppleDouble
.LSOverride

# ── Project-specific generated / runtime artefacts ──────────────────────────
# Dataset directories (large binary data — mount via volume in containers)
data/

# ArrowSpace index stores (runtime-generated graph-Laplacian indices)
# To remove already-tracked content run:
#   git rm -r --cached arrowspace_index/ _arrowspace_index/
#   git commit -m "chore: untrack committed arrowspace index data"
arrowspace_index/*
!arrowspace_index/.gitkeep
_arrowspace_index/*
!_arrowspace_index/.gitkeep

# Zarr arrays (large binary embedding data — never commit raw arrays)
*.zarr/
**/*.zarr/

# Script output / ablation results (regenerate with scripts/)
output_prompt_nomic768/
scripts/embeddings_ablation/

# Notebooks
notebooks/db.json
backrev.md
*.npy
