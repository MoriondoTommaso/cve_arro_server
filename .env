# ── Data roots ────────────────────────────────────────────────────────────────
# The Zarr dataset the server exposes via /api/datasets/*
# Points at the .zarr already in your repo root
ARRO_SERVER_DATA_ROOTS=main=./embeddings_nomic_structured_768d_raw.zarr

# ── Index store ───────────────────────────────────────────────────────────────
# Where the built GL index lives — already populated in your repo
ARRO_SERVER_INDEX_STORE=./arrowspace_index


# * = allow all origins (fine for local dev; restrict in production)
ARRO_SERVER_CORS_ORIGINS=*

# Window / pagination
ARRO_SERVER_DEFAULT_WINDOW=100
ARRO_SERVER_MAX_WINDOW=10000000

# Index cache
ARRO_SERVER_INDEX_CACHE_SIZE=8

# Frontend
# Serves ./frontend/ at http://localhost:8000/ui
ARRO_SERVER_SERVE_FRONTEND=true
ARRO_SERVER_FRONTEND_DIR=./frontend